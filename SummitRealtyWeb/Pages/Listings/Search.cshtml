@page
@model SummitRealtyWeb.Pages.Listings.SearchModel
@{
    ViewData["Title"] = "Property Search";
}

<h1>Property Search</h1>

<form method="get" class="bg-light p-3 mb-4 rounded">
    <div class="row g-3">
        <div class="col-md-3">
            <label for="city" class="form-label">City</label>
            <input type="text" class="form-control" id="city" name="city" value="@Model.City" />
        </div>
        <div class="col-md-3">
            <label for="state" class="form-label">State</label>
            <select class="form-select" id="state" name="state">
                <option value="">All States</option>
                <option value="CA" selected="@(Model.State == "CA")">California</option>
                <option value="TX" selected="@(Model.State == "TX")">Texas</option>
                <option value="FL" selected="@(Model.State == "FL")">Florida</option>
                <option value="NY" selected="@(Model.State == "NY")">New York</option>
                <option value="WA" selected="@(Model.State == "WA")">Washington</option>
            </select>
        </div>
        <div class="col-md-3">
            <label for="minPrice" class="form-label">Min Price</label>
            <input type="number" class="form-control" id="minPrice" name="minPrice" value="@Model.MinPrice" />
        </div>
        <div class="col-md-3">
            <label for="maxPrice" class="form-label">Max Price</label>
            <input type="number" class="form-control" id="maxPrice" name="maxPrice" value="@Model.MaxPrice" />
        </div>
    </div>
    <div class="row g-3 mt-1">
        <div class="col-md-3">
            <label for="bedrooms" class="form-label">Bedrooms</label>
            <select class="form-select" id="bedrooms" name="bedrooms">
                <option value="">Any</option>
                <option value="1" selected="@(Model.Bedrooms == 1)">1+</option>
                <option value="2" selected="@(Model.Bedrooms == 2)">2+</option>
                <option value="3" selected="@(Model.Bedrooms == 3)">3+</option>
                <option value="4" selected="@(Model.Bedrooms == 4)">4+</option>
            </select>
        </div>
        <div class="col-md-3">
            <label for="propertyType" class="form-label">Property Type</label>
            <select class="form-select" id="propertyType" name="propertyType">
                <option value="">All Types</option>
                <option value="Single Family" selected="@(Model.PropertyType == "Single Family")">Single Family</option>
                <option value="Condo" selected="@(Model.PropertyType == "Condo")">Condo</option>
                <option value="Townhouse" selected="@(Model.PropertyType == "Townhouse")">Townhouse</option>
                <option value="Multi-Family" selected="@(Model.PropertyType == "Multi-Family")">Multi-Family</option>
            </select>
        </div>
        <div class="col-md-6 d-flex align-items-end gap-2">
            <button type="submit" class="btn text-white fw-bold" style="background-color: #003366;">Search</button>
            <a asp-page="/Listings/Search" class="btn btn-secondary fw-bold">Clear</a>
        </div>
    </div>
</form>

<h2>Search Results</h2>

@if (Model.Results.Any())
{
    <div class="row">
        @foreach (var property in Model.Results)
        {
            var photo = property.Photos.FirstOrDefault();
            <div class="col-md-6 mb-4">
                <div class="card h-100">
                    <div class="row g-0">
                        <div class="col-md-5">
                            @if (photo != null)
                            {
                                <img src="@photo.FilePath" class="img-fluid rounded-start" alt="Property Photo" style="height: 100%; object-fit: cover;">
                            }
                            else
                            {
                                <img src="/images/no-photo.jpg" class="img-fluid rounded-start" alt="No Photo Available" style="height: 100%; object-fit: cover;">
                            }
                        </div>
                        <div class="col-md-7">
                            <div class="card-body">
                                <h5 class="card-title">@property.Address</h5>
                                <p class="card-text text-muted mb-1">@property.City, @property.State</p>
                                <p class="card-text fw-bold fs-5 mb-1" style="color: #003366;">@property.Price.ToString("C0")</p>
                                <p class="card-text mb-1">@property.Bedrooms BD | @property.Bathrooms BA | @property.SquareFeet sq ft</p>
                                <p class="card-text mb-1">@property.PropertyType</p>
                                <p class="card-text"><strong>Agent:</strong> @property.Agent.FullName</p>
                                <a asp-page="/Listings/Detail" asp-route-id="@property.PropertyId" class="btn btn-sm text-white" style="background-color: #003366;">View Details</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
    <p><strong>@Model.Results.Count</strong> properties found.</p>
}
else
{
    <div class="alert alert-info">
        No properties found matching your criteria. Please adjust your search parameters.
    </div>
}
